+static bool cgroup_noprefix_compat_name(struct cgroup *cgrp,
+					 const struct cftype *cft, char *buf)
+{
+	if (!(cgrp->root->flags & CGRP_ROOT_NOPREFIX))
+		return false;
+	if (!cft->ss || (cft->flags & CFTYPE_NO_PREFIX))
+		return false;
+	if (!cft->ss->legacy_name || strcmp(cft->ss->legacy_name, "cpuset"))
+		return false;
+	if (strcmp(cft->name, "cpus") && strcmp(cft->name, "mems"))
+		return false;
+
+	snprintf(buf, CGROUP_FILE_NAME_MAX, "%s.%s",
+		 cft->ss->legacy_name, cft->name);
+	return true;
+}
